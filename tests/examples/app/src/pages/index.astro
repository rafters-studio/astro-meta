---
import Base from "../layouts/Base.astro";
---

<Base pageTitle="astro-meta example">
  <header>
    <h1>@rafters/astro-meta -- example</h1>
    <p>
      The layout composes SiteMeta + SchemaScript from the package. The
      integration writes robots.txt and sitemap.xml; nothing mutates this
      page's HTML after Astro emits it.
    </p>
  </header>
  <main>
    <h2>Routes</h2>
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </main>
  <footer>
    <p>
      Source:
      <a href="https://github.com/rafters-studio/astro-meta"
        >github.com/rafters-studio/astro-meta</a
      >
    </p>
  </footer>
</Base>
